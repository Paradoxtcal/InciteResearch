# ── LLM Provider (optional) ─────────────────────
# If empty, the app will auto-pick the first available provider key.
RESEARCH_AGENT_LLM_PROVIDER=

# ── Gemini (optional) ───────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI (optional) ───────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ── Anthropic (optional) ────────────────────────
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Optional: increase GitHub search rate limit ──
# GITHUB_TOKEN=

# ── Optional: persistent storage ────────────────
# DATABASE_URL=sqlite:///incite_research.db

# ── Optional: paper/PDF cache ───────────────────
# RESEARCH_AGENT_CACHE_DIR=.research_agent_cache
RESEARCH_AGENT_PAPER_MIN=25
RESEARCH_AGENT_PAPER_LIMIT=100
# RESEARCH_AGENT_AUTO_READ_PDF=1
# RESEARCH_AGENT_AUTO_READ_PDF_MAX=4
# RESEARCH_AGENT_PDF_MAX_PAGES=12
# RESEARCH_AGENT_PDF_MAX_CHARS=30000
